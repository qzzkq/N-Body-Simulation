# Doxyfile для N-Body Simulation
# Генерация: cd project && doxygen docs/Doxyfile
# HTML-документация появится в docs/html/

PROJECT_NAME           = "N-Body Simulation"
PROJECT_BRIEF          = "Интерактивный 3D N-body гравитационный симулятор"
PROJECT_NUMBER         = "1.0"

OUTPUT_DIRECTORY       = docs/
INPUT                  = project/include 
FILE_PATTERNS          = *.hpp *.cuh *.cpp *.cu
RECURSIVE              = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES

GENERATE_HTML          = YES
GENERATE_LATEX         = NO

HAVE_DOT               = NO
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO

JAVADOC_AUTOBRIEF      = YES
OPTIMIZE_OUTPUT_FOR_C  = NO

HTML_OUTPUT            = html
HTML_COLORSTYLE        = DARK

SORT_MEMBER_DOCS       = NO
SHOW_USED_FILES        = YES
SHOW_FILES             = YES
SHOW_NAMESPACES        = YES
